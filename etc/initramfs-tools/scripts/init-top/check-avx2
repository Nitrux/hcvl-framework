PREREQ=""

prereqs() {
    echo "${PREREQ}"
}

case "$1" in
    prereqs) prereqs; exit 0 ;;
esac

# -- Begin real processing below this line

panic_halt() {
    if command -v plymouth >/dev/null 2>&1; then
        plymouth --quit
    fi

    printf '%s\n' "=================================================================" >/dev/console
    printf '%s\n' "CRITICAL HARDWARE FAILURE: UNSUPPORTED CPU DETECTED" >/dev/console
    printf '%s\n' "=================================================================" >/dev/console
    printf '%s\n' "Nitrux requires a CPU with AVX2 instruction set support." >/dev/console
    printf '%s\n' "Your processor does not meet the minimum requirements." >/dev/console
    printf '%s\n' "The system will now halt." >/dev/console
    printf '%s\n' "=================================================================" >/dev/console

    sleep 10

    if command -v poweroff >/dev/null 2>&1; then
        poweroff -f
    fi

    while :; do sleep 3600; done
}

if ! grep -q "avx2" /proc/cpuinfo 2>/dev/null; then
    panic_halt
fi
